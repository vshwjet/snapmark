{
  "name": "design-qa",
  "version": "0.1.0",
  "description": "Drop-in design QA annotation tool for React frontends",
  "license": "MIT",
  "type": "module",
  "main": "./dist/design-qa.cjs",
  "module": "./dist/design-qa.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/design-qa.js",
      "require": "./dist/design-qa.cjs"
    },
    "./dist/style.css": "./dist/style.css",
    "./style.css": "./dist/style.css"
  },
  "bin": {
    "design-qa": "./bin/init.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test-app:dev": "npm --prefix test-app run dev",
    "test-app:build": "npm --prefix test-app run build",
    "test-app-next:dev": "npm --prefix test-app-next run dev",
    "test-app-next:build": "npm --prefix test-app-next run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "html2canvas-pro": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-dts": "^4.5.4"
  }
}
